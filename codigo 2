# MÓDULO 2: CONTROL DE INVENTARIO DE BOTELLAS VACÍAS 
def pedir_entero(mensaje):
    while True:
        try:
            valor = int(input(mensaje))
            if valor < 0:
                print("Error: el valor debe ser un número positivo.")
            else:
                return valor
        except ValueError:
            print("Error: debe ingresar un número entero válido.")

def control_inventario():
    cantidad_actual = pedir_entero("¿Cuántas unidades de botellas vacías hay actualmente en bodega? ")
    consumo_diario = pedir_entero("¿Cuántas botellas vacías consume la planta en promedio por día? ")

    dia = 0
    cantidad_restante = cantidad_actual
    mensaje_alerta = ""

    while cantidad_restante >= consumo_diario:
        dia += 1
        cantidad_restante -= consumo_diario
        print(f"Día {dia}: Inventario restante = {cantidad_restante} unidades")

        if cantidad_restante < 500:
            dias_restantes = cantidad_restante // consumo_diario
            mensaje_alerta = f"¡¡ ALERTA !! Inventario crítico. Quedan {dias_restantes} días antes del desabastecimiento."
            print(mensaje_alerta)
            break
    print("Fin de la simulación. Inventario agotado o crítico.")

if __name__ == "__main__":
    control_inventario()
